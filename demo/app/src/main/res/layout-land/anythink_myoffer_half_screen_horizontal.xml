<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/anythink_dailog_background_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.anythink.basead.p025ui.RoundCornerRelativeLayout
        android:id="@+id/anythink_myoffer_rl_root"
        android:layout_width="match_parent"
        android:layout_height="310dp"
        android:layout_marginTop="38dp"
        android:layout_marginBottom="28dp"
        android:layout_centerHorizontal="true">
        <com.anythink.basead.p025ui.PlayerView
            android:id="@+id/anythink_myoffer_player_view_id"
            android:layout_width="match_parent"
            android:layout_height="162dp"/>
        <include layout="@layout/anythink_myoffer_include_guide2click_mask"/>
        <include layout="@layout/anythink_myoffer_include_guide2click_container"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/anythink_myoffer_button_group"
            android:paddingLeft="12dp"
            android:paddingTop="12dp"
            android:paddingRight="12dp"
            android:paddingBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true">
            <include
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                layout="@layout/anythink_myoffer_feedback_button"/>
            <com.anythink.basead.p025ui.CountDownView
                android:id="@+id/anythink_myoffer_count_down_view_id"
                android:layout_width="@dimen/anythink_myoffer_half_screen_button_size"
                android:layout_height="@dimen/anythink_myoffer_half_screen_button_size"
                android:layout_marginLeft="12dp"
                android:layout_toLeftOf="@+id/anythink_myoffer_btn_close_id"/>
            <com.anythink.basead.p025ui.CloseImageView
                android:id="@+id/anythink_myoffer_btn_close_id"
                android:background="@drawable/anythink_myoffer_base_close_icon"
                android:layout_width="@dimen/anythink_myoffer_half_screen_button_size"
                android:layout_height="@dimen/anythink_myoffer_half_screen_button_size"
                android:layout_marginLeft="12dp"
                android:layout_alignParentRight="true"/>
        </LinearLayout>
        <com.anythink.basead.p025ui.MuteImageView
            android:id="@+id/anythink_myoffer_btn_mute_id"
            android:background="@drawable/anythink_myoffer_video_mute_icon"
            android:layout_width="@dimen/anythink_myoffer_half_screen_button_size"
            android:layout_height="@dimen/anythink_myoffer_half_screen_button_size"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="12dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"/>
        <com.anythink.basead.p025ui.PanelView
            android:id="@+id/anythink_myoffer_banner_view_id"
            android:layout_width="match_parent"
            android:layout_height="162dp"
            android:layout_alignParentBottom="true"/>
    </com.anythink.basead.p025ui.RoundCornerRelativeLayout>
    <include
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="24dp"
        android:layout_alignTop="@+id/anythink_myoffer_rl_root"
        android:layout_alignBottom="@+id/anythink_myoffer_rl_root"
        android:layout_alignParentLeft="true"
        layout="@layout/anythink_myoffer_include_invalid_button"/>
</RelativeLayout>
