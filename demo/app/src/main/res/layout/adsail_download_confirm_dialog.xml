<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#00000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/adsail_download_confirm_root"
        android:background="@drawable/adsail_download_confirm_background_portrait"
        android:paddingLeft="8dp"
        android:paddingTop="16dp"
        android:paddingRight="8dp"
        android:paddingBottom="15dp"
        android:layout_width="match_parent"
        android:layout_height="450dp"
        android:layout_alignParentBottom="true">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APP详情"
                android:layout_centerInParent="true"/>
            <ImageView
                android:id="@+id/adsail_download_confirm_close"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/adsail_ic_download_confirm_close"
                android:layout_alignParentRight="true"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="20dp">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/adsail_download_confirm_content"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <FrameLayout
                    android:id="@+id/adsail_download_confirm_holder"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <ScrollView
                        android:scrollbars="none"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <LinearLayout
                            android:orientation="vertical"
                            android:paddingBottom="30dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/adsail_dialog_adsail_download_imageview"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/adsail_download_round"
                                android:scaleType="fitXY"/>
                            <LinearLayout
                                android:orientation="vertical"
                                android:id="@+id/adsail_app_info_mparent"
                                android:background="@drawable/adsail_bg_gray"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="8dp"
                                android:layout_marginTop="20dp"
                                android:layout_marginRight="8dp">
                                <LinearLayout
                                    android:id="@+id/adsail_app_name_ll"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="15dp"
                                        android:text="应用名称 :"/>
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:id="@+id/adsail_app_name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="15dp"
                                        android:text=""/>
                                </LinearLayout>
                                <LinearLayout
                                    android:id="@+id/adsail_app_ver_ll"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="8dp"
                                        android:text="版本号     :"/>
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:id="@+id/adsail_app_ver"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="8dp"
                                        android:text=""/>
                                </LinearLayout>
                                <LinearLayout
                                    android:id="@+id/adsail_developer_ll"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="8dp"
                                        android:text="开发者     :"/>
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:id="@+id/adsail_developer"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="8dp"
                                        android:text=""/>
                                </LinearLayout>
                                <LinearLayout
                                    android:id="@+id/adsail_app_size_ll"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="8dp"
                                        android:text="包体大小 :"/>
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:id="@+id/adsail_app_size"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="8dp"
                                        android:text=""/>
                                </LinearLayout>
                                <LinearLayout
                                    android:id="@+id/adsail_app_privacy_ll"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="10dp">
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="8dp"
                                        android:text="隐私权限 :"/>
                                    <TextView
                                        android:textSize="12sp"
                                        android:textColor="#a7a5a8"
                                        android:id="@+id/adsail_app_privacy"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginTop="8dp"
                                        android:layout_marginRight="10dp"
                                        android:text=""/>
                                </LinearLayout>
                            </LinearLayout>
                            <TextView
                                android:textSize="18sp"
                                android:textColor="#000000"
                                android:id="@+id/adsail_privacyTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="18dp"
                                android:layout_marginTop="30dp"
                                android:text="权限列表"/>
                            <cn.haorui.sdk.adsail_ad.view.ListViewForScrollView
                                android:id="@+id/adsail_listView"
                                android:background="@null"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="15dp"
                                android:listSelector="@android:color/transparent"
                                android:divider="@null"/>
                        </LinearLayout>
                    </ScrollView>
                </FrameLayout>
                <Button
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:id="@+id/adsail_download_confirm_confirm"
                    android:background="@drawable/adsail_download_confirm_background_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="立即下载"/>
            </LinearLayout>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/adsail_download_confirm_progress_bar"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Button
                android:layout_gravity="center"
                android:id="@+id/adsail_download_confirm_reload_button"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="重新加载"/>
        </FrameLayout>
    </LinearLayout>
</RelativeLayout>
