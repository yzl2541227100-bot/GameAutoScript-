<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/root"
    android:padding="10dp"
    android:layout_width="match_parent"
    android:layout_height="64dp">
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/adsail_icon"
        android:background="#2a90d7"
        android:duplicateParentState="false"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginRight="18dp"
        android:scaleType="center"
        android:layout_marginEnd="18dp"/>
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="14sp"
            android:textColor="#999999"
            android:ellipsize="end"
            android:id="@+id/adsail_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/adsail_download_success"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/desc">
            <TextView
                android:textSize="14sp"
                android:textColor="#999999"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:id="@+id/adsail_download_success_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:singleLine="true"
                android:layout_marginEnd="12dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#999999"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:id="@+id/adsail_download_success_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/adsail_download_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/adsail_desc">
            <TextView
                android:textSize="10sp"
                android:textColor="#999999"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:id="@+id/adsail_download_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_weight="3"/>
            <TextView
                android:textSize="10sp"
                android:textColor="#999999"
                android:ellipsize="end"
                android:gravity="end|center_vertical"
                android:id="@+id/adsail_download_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_weight="2"/>
        </LinearLayout>
    </RelativeLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="#999999"
        android:gravity="center"
        android:layout_gravity="end|center_vertical"
        android:id="@+id/adsail_action"
        android:layout_width="55dp"
        android:layout_height="30dp"
        android:layout_marginLeft="18dp"
        android:layout_weight="0"
        android:layout_marginStart="18dp"/>
</LinearLayout>
