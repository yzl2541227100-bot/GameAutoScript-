<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:background="#ffffff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="35dp"
        android:layout_marginRight="35dp"
        android:layout_centerInParent="true"
        app:cardCornerRadius="11dp"
        app:cardElevation="0dp">
        <RelativeLayout
            android:id="@+id/activity_sdk_interstitial_rl_container"
            android:background="#ffffff"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:id="@+id/activity_sdk_interstitial_containerRL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RelativeLayout
                    android:id="@+id/activity_sdk_interstitial_mediaContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <cn.haorui.sdk.core.view.gif.GifImageView
                        android:id="@+id/activity_sdk_interstitial_imageview"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="fitXY"/>
                </RelativeLayout>
            </RelativeLayout>
            <ImageView
                android:id="@+id/activity_sdk_interstitial_cacel"
                android:padding="5dp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/adsail_close"
                android:scaleType="fitXY"
                android:cropToPadding="true"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"/>
            <ImageView
                android:id="@+id/activity_sdk_interstitial_logo"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="20dp"
                android:src="#00ffff"
                android:layout_below="@+id/activity_sdk_interstitial_containerRL"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:id="@+id/activity_sdk_interstitial_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="20dp"
                android:text="测试数据标题"
                android:layout_toRightOf="@+id/activity_sdk_interstitial_logo"
                android:layout_below="@+id/activity_sdk_interstitial_containerRL"
                android:layout_alignBottom="@+id/activity_sdk_interstitial_logo"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="start"
                android:id="@+id/activity_sdk_interstitial_desc"
                android:background="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="60dp"
                android:layout_marginRight="20dp"
                android:text=""
                android:layout_below="@+id/activity_sdk_interstitial_containerRL"/>
            <TextView
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/activity_sdk_interstitial_btn"
                android:background="@drawable/adsail_bg_button_blue"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="30dp"
                android:layout_marginBottom="30dp"
                android:text="点击查看详情"
                android:layout_below="@+id/activity_sdk_interstitial_desc"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>
