<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/bg_white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/distance_16"
        android:layout_marginBottom="10dp"
        android:text="@string/input_adb_command"
        android:layout_above="@+id/et_adb_command"
        android:layout_centerHorizontal="true"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText
            android:textSize="18sp"
            android:gravity="left"
            android:id="@+id/et_adb_command"
            android:background="@color/gray1"
            android:padding="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:layout_alignParentLeft="true"/>
        <Button
            android:textColor="@android:color/white"
            android:id="@+id/dialog_save_command"
            android:background="@drawable/button_blue_corner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="30dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="@dimen/distance_16"
            android:text="@string/save"
            android:layout_below="@+id/et_adb_command"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
</LinearLayout>
